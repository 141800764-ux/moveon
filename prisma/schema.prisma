generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// AUTH
// ============================================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================================
// USERS & ROLES
// ============================================================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          UserRole  @default(CUSTOMER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts        Account[]
  sessions        Session[]
  staffProfile    Staff?
  driverProfile   Driver?
  customerProfile Customer?
}

enum UserRole {
  SUPER_ADMIN
  CARRIER_ADMIN
  DISPATCHER
  WAREHOUSE_MANAGER
  DRIVER
  CUSTOMER
}

// ============================================================
// CARRIER (the logistics business using MoveOn)
// ============================================================

model Carrier {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  email       String
  phone       String?
  address     Json?
  logo        String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  staff      Staff[]
  vehicles   Vehicle[]
  drivers    Driver[]
  hubs       Hub[]
  orders     Order[]
  shipments  Shipment[]
}

// ============================================================
// STAFF PROFILE (admins, dispatchers, warehouse managers)
// ============================================================

model Staff {
  id         String    @id @default(cuid())
  userId     String    @unique
  carrierId  String
  fullName   String
  phone      String?
  role       UserRole
  isActive   Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  carrier Carrier @relation(fields: [carrierId], references: [id])
}

// ============================================================
// DRIVER PROFILE
// ============================================================

model Driver {
  id                String       @id @default(cuid())
  userId            String       @unique
  carrierId         String
  fullName          String
  phone             String
  licenseNumber     String
  licenseExpiresAt  DateTime
  licenseClasses    String[]
  status            DriverStatus @default(OFF_DUTY)
  rating            Float?
  totalDeliveries   Int          @default(0)
  isActive          Boolean      @default(true)
  avatar            String?
  bio               String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  carrier  Carrier   @relation(fields: [carrierId], references: [id])
  vehicle  Vehicle?  @relation(fields: [vehicleId], references: [id])
  vehicleId String?
  routes   Route[]
  shifts   DriverShift[]
}

enum DriverStatus {
  OFF_DUTY
  ON_DUTY
  ON_ROUTE
  ON_BREAK
  UNAVAILABLE
}

// ============================================================
// CUSTOMER PROFILE
// ============================================================

model Customer {
  id           String   @id @default(cuid())
  userId       String   @unique
  fullName     String
  phone        String?
  address      Json?
  city         String?
  country      String   @default("ZA")
  avatar       String?
  bio          String?
  totalOrders  Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]
}

// ============================================================
// HUBS (depots, warehouses, sorting centers)
// ============================================================

model Hub {
  id        String   @id @default(cuid())
  carrierId String
  name      String
  code      String
  type      HubType
  address   Json
  latitude  Float
  longitude Float
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  carrier   Carrier    @relation(fields: [carrierId], references: [id])
  vehicles  Vehicle[]
  routes    Route[]

  @@unique([carrierId, code])
}

enum HubType {
  DEPOT
  WAREHOUSE
  SORTING_CENTER
  PICKUP_POINT
}

// ============================================================
// VEHICLES
// ============================================================

model Vehicle {
  id              String        @id @default(cuid())
  carrierId       String
  hubId           String?
  registration    String
  make            String
  model           String
  year            Int?
  type            VehicleType
  capacityKg      Float?
  capacityParcels Int?
  status          VehicleStatus @default(AVAILABLE)
  isActive        Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  carrier Carrier  @relation(fields: [carrierId], references: [id])
  hub     Hub?     @relation(fields: [hubId], references: [id])
  drivers Driver[]
  routes  Route[]

  @@unique([carrierId, registration])
}

enum VehicleType {
  BIKE
  CAR
  VAN
  TRUCK
  REFRIGERATED
}

enum VehicleStatus {
  AVAILABLE
  ON_ROUTE
  SERVICING
  OUT_OF_SERVICE
}

// ============================================================
// ORDERS
// ============================================================

model Order {
  id              String      @id @default(cuid())
  carrierId       String
  customerId      String
  trackingNumber  String      @unique
  status          OrderStatus @default(PENDING)
  serviceLevel    String      @default("STANDARD")
  origin          Json
  destination     Json
  recipientName   String
  recipientPhone  String
  recipientEmail  String?
  weightKg        Float?
  notes           String?
  declaredValue   Decimal?    @db.Decimal(12, 2)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  carrier   Carrier   @relation(fields: [carrierId], references: [id])
  customer  Customer  @relation(fields: [customerId], references: [id])
  shipments Shipment[]
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PICKED_UP
  IN_TRANSIT
  OUT_FOR_DELIVERY
  DELIVERED
  FAILED
  CANCELLED
  RETURNED
}

// ============================================================
// SHIPMENTS
// ============================================================

model Shipment {
  id              String         @id @default(cuid())
  carrierId       String
  orderId         String
  trackingNumber  String         @unique
  status          ShipmentStatus @default(CREATED)
  weightKg        Float?
  estimatedAt     DateTime?
  deliveredAt     DateTime?
  podPhotoUrl     String?
  podNotes        String?
  failureReason   String?
  attemptCount    Int            @default(0)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  carrier  Carrier         @relation(fields: [carrierId], references: [id])
  order    Order           @relation(fields: [orderId], references: [id])
  events   ShipmentEvent[]
  stops    Stop[]
}

enum ShipmentStatus {
  CREATED
  IN_TRANSIT
  OUT_FOR_DELIVERY
  DELIVERED
  FAILED
  RETURNED
  CANCELLED
}

model ShipmentEvent {
  id          String   @id @default(cuid())
  shipmentId  String
  type        String
  description String
  actor       String
  createdAt   DateTime @default(now())

  shipment Shipment @relation(fields: [shipmentId], references: [id])

  @@index([shipmentId, createdAt])
}

// ============================================================
// ROUTES & STOPS
// ============================================================

model Route {
  id             String      @id @default(cuid())
  carrierId      String
  hubId          String
  vehicleId      String?
  driverId       String?
  date           DateTime    @db.Date
  status         RouteStatus @default(PLANNED)
  plannedStartAt DateTime?
  plannedEndAt   DateTime?
  actualStartAt  DateTime?
  actualEndAt    DateTime?
  totalDistanceKm Float?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  hub     Hub      @relation(fields: [hubId], references: [id])
  vehicle Vehicle? @relation(fields: [vehicleId], references: [id])
  driver  Driver?  @relation(fields: [driverId], references: [id])
  stops   Stop[]
}

enum RouteStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model Stop {
  id               String     @id @default(cuid())
  routeId          String
  shipmentId       String?
  sequence         Int
  type             StopType
  address          Json
  latitude         Float
  longitude        Float
  contactName      String?
  contactPhone     String?
  plannedArrivalAt DateTime?
  actualArrivalAt  DateTime?
  status           StopStatus @default(PENDING)
  failureReason    String?
  podPhotoUrl      String?
  notes            String?

  route    Route     @relation(fields: [routeId], references: [id])
  shipment Shipment? @relation(fields: [shipmentId], references: [id])

  @@unique([routeId, sequence])
}

enum StopType {
  PICKUP
  DELIVERY
  HUB
}

enum StopStatus {
  PENDING
  COMPLETED
  FAILED
  SKIPPED
}

// ============================================================
// DRIVER SHIFTS
// ============================================================

model DriverShift {
  id        String    @id @default(cuid())
  driverId  String
  startedAt DateTime
  endedAt   DateTime?
  startKm   Int?
  endKm     Int?
  notes     String?

  driver Driver @relation(fields: [driverId], references: [id])

  @@index([driverId, startedAt])
}